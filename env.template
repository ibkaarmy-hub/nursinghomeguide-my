# Copy this file to .env.local and fill in your tokens.
# .env.local is gitignored — never commit real tokens.

# Google OAuth access token (for reading/writing Google Sheets)
# Get one from: https://developers.google.com/oauthplayground
# Scope: https://www.googleapis.com/auth/spreadsheets
# Valid for ~1 hour — refresh when expired
GOOGLE_TOKEN=ya29.xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub Personal Access Token (for uploading photos to the repo)
# Create at: https://github.com/settings/tokens/new?scopes=public_repo
# Scope: public_repo — does not expire unless you set an expiry
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
